DEBURAPY_PORT=8787
DEBURAPY_HOST=127.0.0.1
DEBURAPY_DATA_DIR=.deburapy-data
# Deburapy has no built-in auth. Keep this disabled unless you put the server
# behind your own auth boundary.
DEBURAPY_ALLOW_UNSAFE_BIND=0

# Optional MCP companion defaults.
DEBURAPY_URL=http://127.0.0.1:8787
DEBURAPY_ROOM_ID=default
DEBURAPY_PARTICIPANT_ID=companion
DEBURAPY_CLAUDE_CHANNEL_NOTIFICATIONS=0
DEBURAPY_POLL_MS=3000
