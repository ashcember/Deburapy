DEBURAPY_PORT=8787
DEBURAPY_HOST=127.0.0.1
DEBURAPY_DATA_DIR=.deburapy-data
# Deburapy has no built-in auth. Keep this disabled unless you put the server
# behind your own auth boundary.
DEBURAPY_ALLOW_UNSAFE_BIND=0

# Optional hosted demo key for a public Vercel demo. This key must stay server
# side only. Use a restricted / low-quota Google AI Studio key for demos.
DEBURAPY_ENABLE_HOSTED_DEMO=0
DEBURAPY_HOSTED_DEMO_GOOGLE_AI_STUDIO_API_KEY=
DEBURAPY_HOSTED_DEMO_MODEL=gemini-3.5-flash
DEBURAPY_HOSTED_DEMO_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
DEBURAPY_HOSTED_DEMO_RATE_LIMIT_PER_MINUTE=12

# Optional MCP companion defaults.
DEBURAPY_URL=http://127.0.0.1:8787
DEBURAPY_ROOM_ID=default
DEBURAPY_PARTICIPANT_ID=companion
DEBURAPY_CLAUDE_CHANNEL_NOTIFICATIONS=0
DEBURAPY_POLL_MS=3000
